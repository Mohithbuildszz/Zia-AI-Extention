{
  "name": "codetutor",
  "displayName": "Zia AI",
  "description": "AI-powered coding mentor for VS Code.",
  "version": "0.0.1",
  "publisher": "mohith",
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onView:zia-ai.chatView"
  ],
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Zia AI",
      "properties": {
        "zia-ai.ollamaBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL of the local Ollama server."
        },
        "zia-ai.model": {
          "type": "string",
          "default": "qwen3.5:latest ",
          "description": "Ollama model name."
        },
        "zia-ai.systemPrompt": {
          "type": "string",
          "default": "You are Zia AI, a concise and helpful coding assistant inside VS Code.",
          "description": "System prompt sent to Ollama."
        },
        "zia-ai.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature."
        },
        "zia-ai.maxHistoryMessages": {
          "type": "number",
          "default": 12,
          "minimum": 2,
          "maximum": 50,
          "description": "Maximum chat history."
        }
      }
    },
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "zia-ai-sidebar",
          "title": "Zia AI",
          "icon": "media/download.svg"
        }
      ]
    },
    "views": {
      "zia-ai-sidebar": [
        {
          "type": "webview",
          "id": "zia-ai.chatView",
          "name": "Focus AI Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "zia-ai.focusChat",
        "title": "Zia AI: Focus AI Chat",
        "category": "Zia AI"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "zia-ai.focusChat",
          "when": "view == zia-ai.chatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "apache-arrow": "^18.1.0",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "ollama": "^0.6.3",
    "pdfkit": "^0.19.1",
    "tree-sitter-javascript": "^0.25.0",
    "ts-morph": "^28.0.0",
    "web-tree-sitter": "^0.26.9"
  }
}
